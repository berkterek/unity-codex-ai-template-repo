root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4
charset = utf-8

[*.{unity,prefab,asset,mat,controller,anim,overrideController}]
indent_style = space
indent_size = 2

[*.{json,asmdef,asmref,inputactions}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
