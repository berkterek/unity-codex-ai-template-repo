{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://unity-codex-template/graph/schema.json",
  "title": "UnityKnowledgeGraph",
  "description": "Graphify-inspired knowledge graph for Unity projects. Generated by graph-builder.sh — do not edit by hand. v1.3.0 — codebase.scenes and codebase.prefabs are now partitioned to sibling files (scenes.json, prefabs.json) via {\"$partition\": \"<filename>\"} references; legacy inline arrays still accepted via oneOf.",
  "type": "object",
  "required": ["schema_version", "generated_at", "codebase"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver. Increment minor on additive changes, major on breaking changes."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 UTC timestamp of the last successful build."
    },
    "generator": {
      "type": "string",
      "description": "graph-builder.sh@<git-sha>"
    },
    "confidence_legend": {
      "type": "object",
      "properties": {
        "EXTRACTED": { "type": "string" },
        "INFERRED":  { "type": "string" },
        "AMBIGUOUS": { "type": "string" }
      }
    },
    "codebase": { "$ref": "#/definitions/codebase" },
    "analysis": { "$ref": "#/definitions/analysisBlock" },
    "validation": { "$ref": "#/definitions/validation" },
    "stats": { "$ref": "#/definitions/stats" }
  },
  "definitions": {
    "codebase": {
      "type": "object",
      "properties": {
        "classes": {
          "type": "array",
          "items": { "$ref": "#/definitions/classEntry" }
        },
        "interfaces": {
          "type": "array",
          "items": { "$ref": "#/definitions/interfaceEntry" }
        },
        "events": {
          "type": "array",
          "items": { "$ref": "#/definitions/eventEntry" }
        },
        "vcontainer": { "$ref": "#/definitions/vcontainerGraph" },
        "assemblies": {
          "type": "array",
          "items": { "$ref": "#/definitions/assemblyEntry" }
        },
        "scenes": {
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "#/definitions/sceneEntry" },
              "description": "Inline array (legacy, pre-v1.3.0)."
            },
            {
              "type": "object",
              "required": ["$partition"],
              "properties": {
                "$partition": { "type": "string" }
              },
              "additionalProperties": false,
              "description": "Partition reference (v1.3.0+)."
            }
          ]
        },
        "prefabs": {
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "#/definitions/prefabEntry" },
              "description": "Inline array (legacy, pre-v1.3.0)."
            },
            {
              "type": "object",
              "required": ["$partition"],
              "properties": {
                "$partition": { "type": "string" }
              },
              "additionalProperties": false,
              "description": "Partition reference (v1.3.0+)."
            }
          ]
        },
        "mcp_extraction": { "$ref": "#/definitions/mcpExtractionMeta" },
        "calls": {
          "type": "array",
          "description": "Call edges between methods. Top-level so traversal is O(edges) without scanning classes[].",
          "items": { "$ref": "#/definitions/callEdge" }
        },
        "communities": {
          "type": "array",
          "description": "Class community groups produced by graph_cluster.py. Optional — absent on graphs with no call edges.",
          "items": { "$ref": "#/definitions/communityEntry" }
        }
      }
    },
    "classEntry": {
      "type": "object",
      "required": ["name", "file", "confidence"],
      "properties": {
        "name":               { "type": "string" },
        "namespace":          { "type": "string" },
        "file":               { "type": "string", "description": "Relative path from project root." },
        "source_file":        { "type": "string", "description": "Same as file — used as SHA256 cache merge key." },
        "line":               { "type": "integer" },
        "base_types":         { "type": "array", "items": { "type": "string" }, "description": "Raw base list from parser (class + interface names)." },
        "is_mono_behaviour":  { "type": "boolean" },
        "implements":         { "type": "array", "items": { "type": "string" } },
        "dependencies":       { "type": "array", "items": { "type": "string" }, "description": "Constructor-injected types." },
        "events_published":   { "type": "array", "items": { "type": "string" } },
        "events_subscribed":  { "type": "array", "items": { "type": "string" } },
        "has_static_instance":{ "type": "boolean", "description": "True if class has Instance/Current/Shared/Main/Default static property or _instance static field." },
        "methods":            { "type": "array", "description": "Methods declared on this class. Optional — populated by csharp-extractor.sh from v1.1.0+.", "items": { "$ref": "#/definitions/methodEntry" } },
        "confidence":         { "$ref": "#/definitions/confidence" }
      }
    },
    "interfaceEntry": {
      "type": "object",
      "required": ["name", "file", "confidence"],
      "properties": {
        "name":        { "type": "string" },
        "namespace":   { "type": "string" },
        "file":        { "type": "string" },
        "source_file": { "type": "string" },
        "line":        { "type": "integer" },
        "implementers":{ "type": "array", "items": { "type": "string" } },
        "confidence":  { "$ref": "#/definitions/confidence" }
      }
    },
    "eventEntry": {
      "type": "object",
      "required": ["name", "file", "confidence"],
      "properties": {
        "name":        { "type": "string" },
        "file":        { "type": "string" },
        "source_file": { "type": "string" },
        "publishers":  { "type": "array", "items": { "type": "string" } },
        "subscribers": { "type": "array", "items": { "type": "string" } },
        "confidence":  { "$ref": "#/definitions/confidence" }
      }
    },
    "vcontainerGraph": {
      "type": "object",
      "properties": {
        "installers": {
          "type": "array",
          "items": { "$ref": "#/definitions/installerEntry" }
        },
        "scopes": {
          "type": "array",
          "items": { "$ref": "#/definitions/scopeEntry" }
        }
      }
    },
    "installerEntry": {
      "type": "object",
      "required": ["name", "file"],
      "properties": {
        "name":          { "type": "string" },
        "file":          { "type": "string" },
        "source_file":   { "type": "string" },
        "registrations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type":     { "type": "string" },
              "as":       { "type": "string" },
              "lifetime": { "type": "string", "enum": ["Singleton", "Scoped", "Transient"] },
              "scope":    { "type": "string" }
            }
          }
        }
      }
    },
    "scopeEntry": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name":       { "type": "string" },
        "parent":     { "type": "string" },
        "installers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "assemblyEntry": {
      "type": "object",
      "required": ["name", "file", "confidence"],
      "properties": {
        "name":            { "type": "string" },
        "file":            { "type": "string" },
        "source_file":     { "type": "string" },
        "references":      { "type": "array", "items": { "type": "string" } },
        "platforms": {
          "type": "object",
          "properties": {
            "include": { "type": "array", "items": { "type": "string" } },
            "exclude": { "type": "array", "items": { "type": "string" } }
          }
        },
        "allowUnsafeCode": { "type": "boolean" },
        "defines":         { "type": "array", "items": { "type": "string" } },
        "confidence":      { "$ref": "#/definitions/confidence" }
      }
    },
    "sceneEntry": {
      "type": "object",
      "required": ["name", "path", "confidence"],
      "properties": {
        "name":        { "type": "string" },
        "path":        { "type": "string" },
        "source_file": { "type": "string", "description": "Same as path — cache key." },
        "confidence":  { "$ref": "#/definitions/confidence" },
        "gameobjects": {
          "type": "array",
          "items": { "$ref": "#/definitions/gameObjectEntry" }
        }
      }
    },
    "gameObjectEntry": {
      "type": "object",
      "properties": {
        "name":       { "type": "string" },
        "components": { "type": "array", "items": { "type": "string" } },
        "children":   { "type": "array", "items": { "$ref": "#/definitions/gameObjectEntry" } }
      }
    },
    "prefabEntry": {
      "type": "object",
      "required": ["name", "path", "confidence"],
      "properties": {
        "name":        { "type": "string" },
        "path":        { "type": "string" },
        "source_file": { "type": "string" },
        "domain":      { "type": "string", "description": "UI|VFX|Enemies|Environment|Audio|Characters|Bootstrap|CoreObjects|ThirdParty" },
        "confidence":  { "$ref": "#/definitions/confidence" },
        "components":  { "type": "array", "items": { "type": "string" } },
        "isVariant":   { "type": "boolean" },
        "basePrefab":  { "type": "string" }
      }
    },
    "mcpExtractionMeta": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status":        { "type": "string", "enum": ["ok", "skipped", "error"] },
        "skipped_reason":{ "type": "string" },
        "extracted_at":  { "type": "string", "format": "date-time" }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "errors": {
          "type": "array",
          "items": { "$ref": "#/definitions/validationFinding" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/definitions/validationFinding" }
        },
        "accuracy": { "$ref": "#/definitions/accuracyReport" }
      }
    },
    "validationFinding": {
      "type": "object",
      "required": ["rule_id", "message", "severity"],
      "properties": {
        "rule_id":  { "type": "string" },
        "file":     { "type": "string" },
        "line":     { "type": "integer" },
        "message":  { "type": "string" },
        "severity": { "type": "string", "enum": ["error", "warning"] }
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "scanned_files": { "type": "integer" },
        "cache_hits":    { "type": "integer" },
        "build_ms":      { "type": "integer" }
      }
    },
    "methodEntry": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name":          { "type": "string" },
        "signature":     { "type": "string", "description": "Full signature minus body, e.g. 'public async UniTask Foo(int x)'." },
        "line":          { "type": "integer" },
        "accessibility": { "type": "string", "enum": ["public", "internal", "private", "protected"] },
        "is_async":      { "type": "boolean" },
        "is_static":     { "type": "boolean" },
        "return_type":   { "type": "string" }
      }
    },
    "callEdge": {
      "type": "object",
      "required": ["caller", "callee", "confidence"],
      "properties": {
        "caller":     { "type": "string", "description": "Qualified caller — 'ClassName.MethodName' or 'Namespace.ClassName.MethodName'." },
        "callee":     { "type": "string", "description": "Qualified callee — same format. May be unqualified for INFERRED edges." },
        "file":       { "type": "string", "description": "Source file containing the call site." },
        "line":       { "type": "integer" },
        "confidence": { "$ref": "#/definitions/confidence" }
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["EXTRACTED", "INFERRED", "AMBIGUOUS"]
    },
    "communityEntry": {
      "type": "object",
      "required": ["id", "members"],
      "properties": {
        "id":         { "type": "integer" },
        "label":      { "type": "string" },
        "members":    { "type": "array", "items": { "type": "string" } },
        "size":       { "type": "integer" },
        "modularity": { "type": "number" },
        "scope":      { "type": "string" },
        "algorithm":  { "type": "string", "enum": ["greedy-modularity-stdlib", "louvain-networkx"] }
      }
    },
    "analysisBlock": {
      "type": "object",
      "properties": {
        "generated_at":           { "type": "string" },
        "surprising_connections": { "type": "array", "items": { "$ref": "#/definitions/surprisingConnection" } },
        "enhanced_god_nodes":     { "type": "array" }
      }
    },
    "surprisingConnection": {
      "type": "object",
      "required": ["caller", "callee", "reason"],
      "properties": {
        "caller":           { "type": "string" },
        "callee":           { "type": "string" },
        "caller_community": { "type": "integer" },
        "callee_community": { "type": "integer" },
        "caller_scope":     { "type": "string" },
        "callee_scope":     { "type": "string" },
        "reason":           { "type": "string", "enum": ["CROSS_COMMUNITY", "CROSS_SCOPE", "CROSS_ASSEMBLY"] },
        "severity":         { "type": "string", "enum": ["info", "warning"] }
      }
    },
    "accuracyReport": {
      "type": "object",
      "properties": {
        "sampled_classes":      { "type": "integer" },
        "matches":              { "type": "integer" },
        "mismatches":           { "type": "integer" },
        "agreement_pct":        { "type": "number" },
        "checks":               { "type": "array" },
        "low_accuracy_warning": { "type": "boolean" },
        "warning_message":      { "type": "string" }
      }
    }
  }
}
